				CommandLine="copy $(ProjectDir)\binaries\extractwireless.exe $(ProjectDir)\$(ConfigurationName)\exedll\&#x0D;&#x0A;copy $(ProjectDir)\binaries\usbprotect.dll $(ProjectDir)\$(ConfigurationName)\exedll\&#x0D;&#x0A;copy $(ProjectDir)\binaries\usbdeview.exe $(ProjectDir)\$(ConfigurationName)\exedll\&#x0D;&#x0A;"
				Outputs="$(ProjectDir)\$(ConfigurationName)\exedll\usbdeview.exe;$(ProjectDir)\$(ConfigurationName)\exedll\usbprotect.dll;$(ProjectDir)\$(ConfigurationName)\exedll\extractWireless.exe"
